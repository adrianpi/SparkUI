enum MsgFlags
{
    OK = 0,
    OKCancel = 1,
    YesNo = 2,
    YesNoCancel = 3,

    Info = 0x10,
    Question = 0x20,
    Error = 0x30,
}

class MessageBox
{
    static int Show(string text, string caption, MsgFlags style)
    {
        MsgDialog dlg = new MsgDialog();
        dlg.Title = caption;
        dlg.Message = text;
        dlg.Flags = style;
        
        return dlg.ShowDialog(Window.activeWindow);
    }
}

class Delegate
{
    weak object target;
    void (*method)(object, object, void*);

    Delegate constructor(object target, void* method)
    {
        base();
        this.target = target;
        this.method = method;
        return this;
    }

    void call(object sender, void *args)
    {
        method(target, sender, args);
    }
}

class Event
{
    array<Delegate> handlers = new array<Delegate>();

    void add(Delegate d)
    {
        handlers.add(d);
    }

    void clear()
    {
        handlers.clear();
    }

    void invoke(object sender, void *args)
    {
        for(int i = 0; i < handlers.count; ++i)
        {
            handlers[i].call(sender, args);
        }
    }
}

Event operator+(Event e,  Delegate d)
{
    e.add(d);
    return e;
}

class Application
{
    static int Run()
    {
        // Message loop
        MSG msg = {};
        while (GetMessageA(&msg, null, 0, 0))
        {
            // Check if this is a keyboard message
            if(msg.message == WM_KEYDOWN || msg.message == WM_KEYUP)
            {
                // Send key preview message to focused window
                long focusedHwnd = GetFocus();
                if(focusedHwnd != 0)
                {
                    long result = SendMessageA(focusedHwnd, WM_USER_KEY_PREVIEW, msg.wParam, msg.lParam);
                    if(result == 1)
                    {
                        // Key preview handled it, skip normal processing and just dispatch
                        DispatchMessageA(&msg);
                        continue;
                    }
                }
            }

            // Skip IsDialogMessage for ENTER and ESC to allow OnKeyDown to handle them
            bool isEnterOrEsc = (msg.message == WM_KEYDOWN && 
                                 (msg.wParam == VK_RETURN || msg.wParam == VK_ESCAPE));

            if(isEnterOrEsc || Window.activeWindow == null || !IsDialogMessage(Window.activeWindow.hWnd, &msg))
            {
                // Don't call TranslateMessage for ENTER/ESC to prevent WM_CHAR beep
                if(!isEnterOrEsc)
                    TranslateMessage(&msg);
                DispatchMessageA(&msg);
            }
        }

        return msg.wParam;
    }

    static void Exit(int exitCode)
    {
        PostQuitMessage(exitCode);
    }
}


