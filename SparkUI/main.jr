    static Bitmap CheckboxUnchecked = Bitmap.FromStream(GetResourceStream(Checkbox_Unchecked, sizeof(Checkbox_Unchecked)));
    static Bitmap CheckboxDim = Bitmap.FromStream(GetResourceStream(Checkbox_Dim, sizeof(Checkbox_Dim)));

    static Bitmap RadiobuttonChecked = Bitmap.FromStream(GetResourceStream(Radiobutton_Checked, sizeof(Radiobutton_Checked)));
    static Bitmap RadiobuttonUnchecked = Bitmap.FromStream(GetResourceStream(Radiobutton_Unchecked, sizeof(Radiobutton_Unchecked)));
    static Bitmap RadiobuttonDim = Bitmap.FromStream(GetResourceStream(Radiobutton_Dim, sizeof(Radiobutton_Dim)));

