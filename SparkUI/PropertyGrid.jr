class ColorPropertyEditor : PropertyEditor
{
    virtual string GetStringValue(object obj, RTTIProperty prop)
    {
        uint value = prop.GetIntValue(obj);
        return string.format("%6.6x", value);
    }

    virtual bool SetStringValue(object obj, RTTIProperty prop, string value)
    {
        uint intValue;
        if(parse_hex(value.c_str(), &intValue))
        {
            prop.SetIntValue(obj, intValue);
            return true;
        }
        return false;
    }

    static Textbox textBox = null;
    static Button button = null;
    object selectedObject = null;
    RTTIProperty selectedProperty = null;

    void OnButtonClicked(object sender, void* args)
    {
        uint value;
        if(parse_hex(textBox.Text.c_str(), &value))
        {
            ChooseColorDialog dlg = new ChooseColorDialog();
            dlg.FullOpen = true;
            dlg.Color = value;
            if(dlg.ShowDialog(button.parent.parent))
            {
                textBox.Text = string.format("%6.6x", dlg.Color);
            }
        }
    }

    void OnEnterEdit(PropertyGrid pgrid, object obj, RTTIProperty prop, int y)
    {
        selectedObject = obj;
        selectedProperty = prop;
        if(textBox == null)
        {
            textBox = new Textbox(pgrid, 0, 0, 99-16-19+1, 19);
            button = new Button(pgrid, 0, 0, 19, 19);
            button.Clicked += new Delegate(this, ColorPropertyEditor.OnButtonClicked);
            button.Text = "...";
        }

        textBox.SetPosition(pgrid.width - 100, y);
        button.SetPosition(pgrid.width - 19-16, y);
        string value = GetStringValue(obj, prop);
        textBox.Text = value;
        textBox.Visible = true;
        button.Visible = true;
        textBox.Focus();
    }

    bool OnLeaveEdit(PropertyGrid pgrid, object obj, RTTIProperty prop)
    {
        if(textBox != null)
        {
            textBox.Visible = false;
            button.Visible = false;
            string value = GetStringValue(obj, prop);
            if(textBox.Text != value)
            {
                if(!SetStringValue(obj, prop, textBox.Text))
                {
                    textBox.Visible = true;
                    button.Visible = true;
                    return false;
                }
            }
            return true;
        }
        return false;
    }

    void CancelEdit(PropertyGrid pgrid, object obj, RTTIProperty prop)
    {
        if(textBox != null)
        {
            textBox.Visible = false;
            button.Visible = false;
        }
    }

    void Draw(Canvas canvas, int x, int y, int width, int height, Font font, uint foreColor, object obj, RTTIProperty prop)
    {
        uint value = prop.GetIntValue(obj);
        Brush brush = new Brush(value);
        canvas.FillRectangle(x, y+3, width, height, brush);
    }
}

class BitmapPropertyEditor : PropertyEditor
{
    virtual string GetStringValue(object obj, RTTIProperty prop)
    {
        return null;
    }

    virtual bool SetStringValue(object obj, RTTIProperty prop, string value)
    {
        return true;
    }

    static Button button = null;
    object selectedObject = null;
    RTTIProperty selectedProperty = null;

    void OnButtonClicked(object sender, void* args)
    {
        OpenFileDialog dlg = new OpenFileDialog();
        dlg.Filter = "Bitmap Files|*.bmp|All Files|*.*|";
        dlg.Title = "Select Bitmap";
        if(dlg.Show(button.parent.parent))
        {
            string fileName = dlg.FileName;
            Bitmap bmp = Bitmap.FromFile(fileName);
            selectedProperty.SetObjectValue(selectedObject, bmp);
            button.parent.Invalidate();
        }
    }

    void OnEnterEdit(PropertyGrid pgrid, object obj, RTTIProperty prop, int y)
    {
        selectedObject = obj;
        selectedProperty = prop;
        if(button == null)
        {
            button = new Button(pgrid, 0, 0, 19, 19);
            button.Clicked += new Delegate(this, BitmapPropertyEditor.OnButtonClicked);
            button.Text = "...";
        }

        button.SetPosition(pgrid.width - 19-16, y);
        button.Visible = true;
    }

    bool OnLeaveEdit(PropertyGrid pgrid, object obj, RTTIProperty prop)
    {
        if(button != null)
        {
            button.Visible = false;
            return true;
        }
        return false;
    }

    void CancelEdit(PropertyGrid pgrid, object obj, RTTIProperty prop)
    {
        if(button != null)
        {
            button.Visible = false;
        }
    }

    void Draw(Canvas canvas, int x, int y, int width, int height, Font font, uint foreColor, object obj, RTTIProperty prop)
    {
        Bitmap value = prop.GetObjectValue(obj) as Bitmap;
        if(value != null)
        {
            int w, h;
            h = height;
            w = value.width * height / value.height;
            canvas.DrawBitmap(x, y+3, w, h, value);
        }
    }
}

class FilenamePropertyEditor : PropertyEditor
{
    string GetStringValue(object obj, RTTIProperty prop)
    {
        object value = prop.GetObjectValue(obj);
        return value as string;
    }

    bool SetStringValue(object obj, RTTIProperty prop, string value)
    {
        prop.SetObjectValue(obj, value);
        return true;
    }

    static Button button = null;
    object selectedObject = null;
    RTTIProperty selectedProperty = null;

    void OnButtonClicked(object sender, void* args)
    {
        OpenFileDialog dlg = new OpenFileDialog();
        dlg.Filter = "All Files|*.*|";
        dlg.Title = "Select File";
        if(selectedProperty.HasAttribute("FilenameFilter"))
            dlg.Filter = selectedProperty.GetAttributeString("FilenameFilter");
        string fileName = selectedProperty.GetObjectValue(selectedObject) as string;
        if(fileName)
            dlg.FileName = fileName;
        if(dlg.Show(button.parent.parent))
        {
            selectedProperty.SetObjectValue(selectedObject, dlg.FileName);
            button.parent.Invalidate();
        }

    }

    void OnEnterEdit(PropertyGrid pgrid, object obj, RTTIProperty prop, int y)
    {
        selectedObject = obj;
        selectedProperty = prop;
        if(button == null)
        {
            button = new Button(pgrid, 0, 0, 19, 19);
            button.Clicked += new Delegate(this, FilenamePropertyEditor.OnButtonClicked);
            button.Text = "...";
        }

        button.SetPosition(pgrid.width - 19-16, y);
        button.Visible = true;
    }

    bool OnLeaveEdit(PropertyGrid pgrid, object obj, RTTIProperty prop)
    {
        if(button != null)
        {
            button.Visible = false;
            return true;
        }
        return false;
    }

    void CancelEdit(PropertyGrid pgrid, object obj, RTTIProperty prop)
    {
        if(button != null)
        {
            button.Visible = false;
        }
    }

    void Draw(Canvas canvas, int x, int y, int width, int height, Font font, uint foreColor, object obj, RTTIProperty prop)
    {
        string value = GetStringValue(obj, prop);
        if(value != null)
            canvas.RenderPathText(x, y + 3, width, height, value, font, foreColor);
    }
}

class PropertyGridProperty
{
    string name;
    int row;
    object target;
    RTTIProperty prop;
    PropertyEditor editor;
    int expands;
    int level;
    PropertyGridProperty constructor(string name, object target, RTTIProperty prop)
    {
        this.name = name;
        this.target = target;
        this.prop = prop;
        return this;
    }
}

bool operator<(PropertyGridProperty a, PropertyGridProperty b)
{
    return a.name < b.name;
}

class PropertyGrid : Control
{
    bool border = true;
    Pen forePen;
    Pen gridPen;
    object selectedObject;
    array<PropertyGridProperty> properties = new array<PropertyGridProperty>();
    VScrollbar vscroll;
    int topIndex;

    [Browsable(false)]
    object get SelectedObject() => selectedObject;
    void set SelectedObject(object value)
    {
        if(editor)
        {
            editor.CancelEdit(this, selectedProperty.target, selectedProperty.prop);
            editor = null;
        }
        selectedProperty = null;
        selectedObject = value;
        GetObjectProperties(properties, selectedObject);
        topIndex = 0;
        vscroll.Position = 0;
        Layout();
        AdjustVScroll();
        Invalidate();
    }

    void AdjustVScroll()
    {
        vscroll.MaxValue = (properties.count - (height / 20)) >? 0;        
        int itemHeight = 20;
        int numVisible = height / itemHeight;
        vscroll.PageSize = numVisible;
        vscroll.Invalidate();
    }

    uint GetWindowStyle()
    {
        return WS_CHILD | WS_VISIBLE | WS_TABSTOP;
    }

    PropertyGrid constructor(Window parent, int x, int y, int w, int h)
    {
        base(parent, x, y, w, h);     
        doubleBuffered = true;
        GetHandle();
        vscroll = new VScrollbar(this, width - 16 - 1, 1, 16, height-2);
        vscroll.Scrolled += new Delegate(this, PropertyGrid.VScroll_Scrolled);
        forePen = new Pen(PS_SOLID, 1, ForeColor);
        gridPen = new Pen(PS_SOLID, 1, 0x444444);
        return this;
    }

    void VScroll_Scrolled(object sender, void* args)
    {
        FinishEdit();
        topIndex = vscroll.Position;
        Layout();
        Invalidate();
    }

    void FinishEdit()
    {
        if(editor != null)
        {
            if(!editor.OnLeaveEdit(this, selectedProperty.target, selectedProperty.prop))
                    editor.CancelEdit(this, selectedProperty.target, selectedProperty.prop);
            editor = null;
            selectedProperty = null;
        }
    }

    bool get Border() => border;
    void set Border(bool value)
    {
        border = value;
        Invalidate();
    }

    PropertyEditor GetEditorForProperty(RTTIProperty prop)
    {
        if(prop.HasAttribute("PropertyEditor"))
        {
            string editorClass = prop.GetAttributeString("PropertyEditor");
            RTTIClassType editorType = RTTIType.GetType(editorClass) as RTTIClassType;
            if(editorType != null)
            {
                PropertyEditor* (*creator)() = editorType.GetCreator().address;
                if(creator != null)
                {
                    PropertyEditor editor = creator();
                    return editor;
                }
            }
        }

        RTTIType type = prop.propertyType;
        if(type.IsEnum())
            return new EnumPropertyEditor();
        else if(type == RTTIType.Bool)
            return new BoolPropertyEditor();
        else if(type == RTTIType.Byte)
            return new BytePropertyEditor();
        else if(type == RTTIType.UByte)
            return new UBytePropertyEditor();
        else if(type == RTTIType.Short)
            return new ShortPropertyEditor();
        else if(type == RTTIType.UShort)
            return new UShortPropertyEditor();
        else if(type == RTTIType.Int)
            return new IntPropertyEditor();
        else if(type == RTTIType.UInt)
            return new UIntPropertyEditor();
        else if(type == RTTIType.Long)
            return new LongPropertyEditor();
        else if(type == RTTIType.ULong)
            return new ULongPropertyEditor();
        else if(type == RTTIType.Float)
            return new FloatPropertyEditor();
        else if(type == RTTIType.Double)
            return new DoublePropertyEditor();
        else if(type.name == "string*")
            return new StringPropertyEditor();
        else if(type.name == "Bitmap*")
            return new BitmapPropertyEditor();
        else
        {
            string editorTypeName = PropertyEditor.editors[type.name];
            if(editorTypeName != null)
            {
                RTTIClassType editorType = RTTIType.GetType(editorTypeName) as RTTIClassType;
                if(editorType != null)
                {
                    PropertyEditor* (*creator)() = editorType.GetCreator().address;
                    if(creator != null)
                    {
                        PropertyEditor editor = creator();
                        return editor;
                    }
                }
            }
            return null;
        }
    }

    void GetClassProperties(array<PropertyGridProperty> properties, RTTIClassType cls, object target)
    {
        if(cls.baseClass != null)
            GetClassProperties(properties, cls.baseClass, target);
        array<string> props = cls.EnumProperties();
        for(int i = 0; i < props.count; i++)
        {
            RTTIProperty prop = cls.GetProperty(props[i]);

            if(prop.HasAttribute("Browsable") && !prop.GetAttributeBool("Browsable"))
                continue;

            if(prop.getter == null || prop.setter == null)
                continue;

            if((prop.getter.flags & (SymbolFlags.Private| SymbolFlags.Protected)) != 0)
                continue;

            if((prop.setter.flags & (SymbolFlags.Private| SymbolFlags.Protected)) != 0)
                continue;

            if((prop.flags & SymbolFlags.Static) == 0)
            {
                string name = prop.name;
                if(prop.HasAttribute("DisplayName"))
                    name = prop.GetAttributeString("DisplayName");
                PropertyGridProperty pgp = new PropertyGridProperty(name, target, prop);
                pgp.editor = GetEditorForProperty(prop);
                properties.add(pgp);
                if(prop.propertyType.IsClassRef() && pgp.editor == null)
                    pgp.expands = 1;
            }
        }
    }

    void GetObjectProperties(array<PropertyGridProperty> properties, object selectedObject)
    {
        properties.clear();
        if(selectedObject != null)
        {
            RTTIClassType type = selectedObject.getClassType();
            GetClassProperties(properties, type, selectedObject);
            properties.sort();
        }
    }

    void Layout()
    {
        for(int i = 0; i < properties.count; i++)
        {
            properties[i].row = i - topIndex;
        }
    }

    void OnPaint(Canvas canvas)
    {
        for(int i = topIndex; i < properties.count; i++)
        {
            PropertyGridProperty prop = properties[i];
            Bitmap icon = null;
            if(prop.expands == 1)
                icon = WindowDefaults.PropertyExpand;
            else if(prop.expands == 2)
                icon = WindowDefaults.PropertyCollapse;
            int x = 5 + prop.level * 8;
            if(icon != null)
                x += 10;
            canvas.RenderText(x, 3 + prop.row * 20, width-100-x, 20, prop.name, this.Font, ForeColor);
            if(prop.editor != null)
                prop.editor.Draw(canvas, width-100, prop.row * 20, 99-16, 19, this.Font, ForeColor, prop.target, prop.prop);
            canvas.DrawLine(1, 2 + (prop.row + 1) * 20, vscroll.x, 2 + (prop.row + 1) * 20, gridPen);
            if(icon != null)
                canvas.DrawBitmap(x - 10, 8 + prop.row * 20, 7, 7, icon);
        }

        if(border)
        {
            canvas.DrawRectangle(0, 0, width, height, forePen);
        }
    }

    PropertyEditor editor;
    PropertyGridProperty selectedProperty;

    PropertyGridProperty GetPropertyAt(int y)
    {
        int index = (y / 20) + topIndex;
        if(index >= 0 && index < properties.count)
        {
            PropertyGridProperty prop = properties[index];
            return prop;
        }
        return null;
    }

    void OnMouseDown(int button, int x, int y)
    {
        if(button == 1)
        {
            PropertyGridProperty prop = GetPropertyAt(y);
            if(prop != null)
            {
                if(prop.expands == 1)
                {
                    prop.expands = 2;
                    array<PropertyGridProperty> subProperties = new array<PropertyGridProperty>();
                    object target = prop.prop.GetObjectValue(prop.target);
                    GetObjectProperties(subProperties, target);
                    int index = properties.indexOf(prop) + 1;
                    for(int i  = 0; i < subProperties.count; ++i)
                    {
                        subProperties[i].level = prop.level + 1;
                        properties.insert(index + i, subProperties[i]);
                    }
                    FinishEdit();
                    Layout();
                    AdjustVScroll();
                    Invalidate();
                }
                else if(prop.expands == 2)
                {
                    prop.expands = 1;
                    int index = properties.indexOf(prop) + 1;
                    while(index < properties.count && properties[index].level > prop.level)
                    {
                        properties.removeAt(index);
                    }
                    FinishEdit();
                    Layout();
                    AdjustVScroll();
                    Invalidate();
                }
                else
                {
                    if(prop.editor != null && editor != prop.editor)
                    {
                        bool leaveOk = true;
                        if(editor != null)
                            leaveOk = editor.OnLeaveEdit(this, selectedProperty.target, selectedProperty.prop);
                        if(leaveOk)
                        {
                            prop.editor.OnEnterEdit(this, prop.target, prop.prop, prop.row * 20+3);
                            editor = prop.editor;
                            selectedProperty = prop;
                        }
                    }
                }
            }
        }
    }

    void OnMouseWheel(int delta, int x, int y)
    {
        if(delta > 0)
        {
            if(vscroll.Position > 0)
            {
                FinishEdit();
                vscroll.Position -= 1;
                topIndex = vscroll.Position;
                Layout();
                Invalidate();
            }
        }
        else if(delta < 0)
        {
            if(vscroll.Position < vscroll.MaxValue)
            {
                FinishEdit();
                vscroll.Position += 1;
                topIndex = vscroll.Position;
                Layout();
                Invalidate();
            }
        }
    }

    void OnSizeChanged()
    {
        if(vscroll != null)
        {
            vscroll.Left = Width - 16 - 1;
            vscroll.Height = Height - 2;
            Layout();
            AdjustVScroll();
        }
    }
}
