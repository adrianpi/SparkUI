using jargon;

int strtol(byte *str, byte **endptr, int _base) external;
uint strtoul(byte *str, byte **endptr, int _base) external;
long strtoll(byte *str, byte **endptr, int _base) external;
ulong strtoull(byte *str, byte **endptr, int _base) external;
float strtof(byte *str, byte **endptr) external;
double strtod(byte *str, byte **endptr) external;

bool parse_byte(byte *str, byte *out)
{
    byte *end;
    int value = strtol(str, &end, 10);
    if (end == str)
        return false;
    if (*end != '\0')
        return false;
    if (value < -128 || value > 127)
        return false;
    *out = (byte)value;
    return true;
}

bool parse_ubyte(byte *str, ubyte *out)
{
    byte *end;
    uint value = strtoul(str, &end, 10);
    if (end == str)
        return false;
    if (*end != '\0')
        return false;
    if (value > 255)
        return false;
    *out = (ubyte)value;
    return true;
}

bool parse_short(byte *str, short *out)
{
    byte *end;
    int value = strtol(str, &end, 10);
    if (end == str)
        return false;
    if (*end != '\0')
        return false;
    if (value < -32768 || value > 32767)
        return false;
    *out = (short)value;
    return true;
}

bool parse_ushort(byte *str, ushort *out)
{
    byte *end;
    uint value = strtoul(str, &end, 10);
    if (end == str)
        return false;
    if (*end != '\0')
        return false;
    if (value > 65535)
        return false;
    *out = (ushort)value;
    return true;
}

bool parse_int(byte *str, int *out)
{
    byte *end;

    int value = strtol(str, &end, 10);

    if (end == str)
        return false;

    if (*end != '\0')
        return false;

    if (value < -2147483648 || value > 2147483647)
        return false;

    *out = (int)value;
    return true;
}

bool parse_uint(byte *str, uint *out)
{
    byte *end;

    uint value = strtoul(str, &end, 10);

    if (end == str)
        return false;

    if (*end != '\0')
        return false;

    if (value > 4294967295)
        return false;

    *out = (uint)value;
    return true;
}

bool parse_hex(byte *str, uint *out)
{
    byte *end;

    uint value = strtoul(str, &end, 16);

    if (end == str)
        return false;

    if (*end != '\0')
        return false;

    *out = (uint)value;
    return true;
}

bool parse_long(byte *str, long *out)
{
    byte *end;

    long value = strtoll(str, &end, 10);

    if (end == str)
        return false;

    if (*end != '\0')
        return false;

    *out = value;
    return true;
}

bool parse_ulong(byte *str, ulong *out)
{
    byte *end;

    ulong value = strtoull(str, &end, 10);

    if (end == str)
        return false;

    if (*end != '\0')
        return false;

    *out = value;
    return true;
}

bool parse_float(byte *str, float *out)
{
    byte *end;

    float value = strtof(str, &end);

    if (end == str)
        return false;

    if (*end != '\0')
        return false;

    *out = value;
    return true;
}

bool parse_double(byte *str, double *out)
{
    byte *end;

    double value = strtod(str, &end);
    if (end == str)
        return false;

    if (*end != '\0')
        return false;

    *out = value;
    return true;
}

string ftrim(string str)
{
    string temp = str;
    if(temp.indexOfChar('.') != -1)
    {
        while(temp[temp.length-1] == '0')
            temp = temp.substr(0, temp.length-1);
        if(temp[temp.length-1] == '.')
            temp = temp + '0';
    }
    return temp;
}



class PropertyEditor
{
    static dictionary<string, string> editors = new dictionary<string, string>();

    static void RegisterEditor(string typeName, string editor)
    {
        editors[typeName] = editor;
    }

    virtual string GetStringValue(object obj, RTTIProperty prop)
    {
        return null;
    }

    virtual bool SetStringValue(object obj, RTTIProperty prop, string value)
    {
        return false;
    }

    virtual void OnEnterEdit(PropertyGrid pgrid, object obj, RTTIProperty prop, int y)
    {
    }

    virtual bool OnLeaveEdit(PropertyGrid pgrid, object obj, RTTIProperty prop)
    {
        return false;
    }

    virtual void CancelEdit(PropertyGrid pgrid, object obj, RTTIProperty prop)
    {
    }

    virtual void Draw(Canvas canvas, int x, int y, int width, int height, Font font, uint foreColor, object obj, RTTIProperty prop)
    {
    }
}

class TextEditor : PropertyEditor
{
    static Textbox textBox = null;

    void OnEnterEdit(PropertyGrid pgrid, object obj, RTTIProperty prop, int y)
    {
        if(textBox == null)
        {
            textBox = new Textbox(pgrid, 0, 0, 99-16, 19);
        }

        textBox.SetPosition(pgrid.width - 100, y);
        string value = GetStringValue(obj, prop);
        textBox.Text = value;
        textBox.Visible = true;
        textBox.Focus();
    }

    bool OnLeaveEdit(PropertyGrid pgrid, object obj, RTTIProperty prop)
    {
        if(textBox != null)
        {
            textBox.Visible = false;
            string value = GetStringValue(obj, prop);
            if(textBox.Text != value)
            {
                if(!SetStringValue(obj, prop, textBox.Text))
                {
                    textBox.Visible = true;
                    return false;
                }
            }
            return true;
        }
        return false;
    }

    void CancelEdit(PropertyGrid pgrid, object obj, RTTIProperty prop)
    {
        if(textBox != null)
        {
            textBox.Visible = false;
        }
    }

    void Draw(Canvas canvas, int x, int y, int width, int height, Font font, uint foreColor, object obj, RTTIProperty prop)
    {
        string value = GetStringValue(obj, prop);
        canvas.DrawText(x, y + 3, value, font, foreColor);
    }
}

class DropdownEditor : PropertyEditor
{
    static Dropdown dropDown = null;

    virtual array<string> GetValues(RTTIProperty prop)
    {
        return null;
    }

    void OnEnterEdit(PropertyGrid pgrid, object obj, RTTIProperty prop, int y)
    {
        if(dropDown == null)
        {
            dropDown = new Dropdown(pgrid, 0, 0, 99-16, 19);
        }
        dropDown.SetPosition(pgrid.width - 100, y);
        string value = GetStringValue(obj, prop);
        dropDown.Text = value;
        dropDown.Items.Clear();
        array<string> values = GetValues(prop);
        if(values != null)
        {
            for(int i = 0; i < values.count; ++i)
            {
                dropDown.Items.Add(values[i]);
                if(value == values[i])
                    dropDown.listbox.SelectedIndex = i;
            }
        }
        dropDown.Visible = true;
        dropDown.Focus();
    }

    bool OnLeaveEdit(PropertyGrid pgrid, object obj, RTTIProperty prop)
    {
        if(dropDown != null)
        {
            dropDown.Visible = false;
            string value = GetStringValue(obj, prop);
            if(dropDown.Text != value)
            {
                if(!SetStringValue(obj, prop, dropDown.Text))
                {
                    dropDown.Visible = true;
                    return false;
                }
            }
            return true;
        }
        return false;
    }

    void CancelEdit(PropertyGrid pgrid, object obj, RTTIProperty prop)
    {
        if(dropDown != null)
        {
            dropDown.Visible = false;
        }
    }

    void Draw(Canvas canvas, int x, int y, int width, int height, Font font, uint foreColor, object obj, RTTIProperty prop)
    {
        string value = GetStringValue(obj, prop);
        canvas.DrawText(x, y + 3, value, font, foreColor);
    }
}

class BoolPropertyEditor : DropdownEditor
{
    array<string> GetValues(RTTIProperty prop)
    {
        array<string> result = new array<string>();
        result.add(new string("false"));
        result.add(new string("true"));
        return result;
    }
    string GetStringValue(object obj, RTTIProperty prop)
    {
        bool value = prop.GetBoolValue(obj);
        return value ? "true" : "false";
    }
    bool SetStringValue(object obj, RTTIProperty prop, string value)
    {
        bool value = value != "false" ? true : false;
        prop.SetBoolValue(obj, value);
        return true;
    }
}

class EnumPropertyEditor : DropdownEditor
{
    array<string> GetValues(RTTIProperty prop)
    {
        array<string> result = new array<string>();
        RTTIEnumType enumType = prop.propertyType as RTTIEnumType;
        if(enumType != null)
        {
            array<string> names = enumType.EnumValues();
            for(int i = 0; i < names.count; ++i)
            {
                result.add(names[i]);
            }
        }
        return result;
    }
    string GetStringValue(object obj, RTTIProperty prop)
    {
        int value = prop.GetIntValue(obj);
        RTTIEnumType enumType = prop.propertyType as RTTIEnumType;
        if(enumType != null)
        {
            return enumType.Stringify(value);
        }
        return "";
    }
    bool SetStringValue(object obj, RTTIProperty prop, string value)
    {
        RTTIEnumType enumType = prop.propertyType as RTTIEnumType;
        if(enumType != null)
        {
            int intValue = enumType.Parse(value);
            prop.SetIntValue(obj, intValue);
            return true;
        }
        return false;
    }
}

class BytePropertyEditor : TextEditor
{
    string GetStringValue(object obj, RTTIProperty prop)
    {
        byte value = prop.GetByteValue(obj);
        return string.format("%d", value);
    }

    bool SetStringValue(object obj, RTTIProperty prop, string value)
    {
        byte byteValue;
        if(parse_byte(value.c_str(), &byteValue))
        {
            prop.SetByteValue(obj, byteValue);
            return true;
        }
        return false;
    }
}

